<Window x:Class="ZapretGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Zapret for ADHD" Height="760" Width="1100"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Border Background="#0A0A0A" CornerRadius="12" BorderBrush="#2A2A2A" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="45"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#121212" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ToggleButton x:Name="MenuToggle" Grid.Column="0" IsChecked="True" Width="45" Height="45" 
                              Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <TextBlock Text="&#xE700;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="16" 
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <ToggleButton.Triggers>
                        <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Sidebar" Storyboard.TargetProperty="Width" 
                                                     To="0" Duration="0:0:0.2" DecelerationRatio="0.9"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="ToggleButton.Checked">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Sidebar" Storyboard.TargetProperty="Width" 
                                                     To="220" Duration="0:0:0.2" DecelerationRatio="0.9"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ToggleButton.Triggers>
                </ToggleButton>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock Text="Zapret for ADHD" Foreground="#888888" FontSize="14" FontWeight="SemiBold" Margin="0,0,20,0"/>

                    <Ellipse x:Name="NetworkDot" Width="8" Height="8" Fill="#107C10" Margin="0,0,5,0"/>
                    <TextBlock Text="Сеть" Foreground="#888888" FontSize="12" Margin="0,0,15,0" VerticalAlignment="Center"/>

                    <Ellipse x:Name="ZapretDot" Width="8" Height="8" Fill="#D13438" Margin="0,0,5,0"/>
                    <TextBlock Text="Zapret" Foreground="#888888" FontSize="12" Margin="0,0,15,0" VerticalAlignment="Center"/>

                    <Ellipse x:Name="TgProxyDot" Width="8" Height="8" Fill="#D13438" Margin="0,0,5,0"/>
                    <TextBlock Text="TgWsProxy" Foreground="#888888" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                    <Button Content="—" Width="35" Height="30" FontSize="14" Background="Transparent" 
                            Foreground="White" BorderThickness="0" Click="BtnMinimize_Click"/>
                    <Button Content="✕" Width="35" Height="30" FontSize="14" Background="Transparent" 
                            Foreground="#D13438" BorderThickness="0" Click="BtnClose_Click"/>
                </StackPanel>

                <Border Grid.ColumnSpan="3" VerticalAlignment="Bottom" Height="1" Background="#2A2A2A"/>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="Sidebar" Grid.Column="0" Width="220" Background="#181818" ClipToBounds="True">
					<StackPanel Width="220" Margin="10,20,10,0">
						<ui:Button x:Name="BtnHome" Content="Главная" Foreground="White" Background="#2A2A2A" BorderBrush="#107C10" BorderThickness="3,0,0,0"
                                   HorizontalAlignment="Stretch" Margin="0,0,0,10" Height="40" Click="BtnHome_Click"/>

						<ui:Button x:Name="BtnServices" Content="Службы" Foreground="White" Appearance="Transparent" BorderThickness="0"
                                   HorizontalAlignment="Stretch" Margin="0,0,0,10" Height="40"/>

						<ui:Button x:Name="BtnMods" Content="Модификации" Foreground="White" Appearance="Transparent" BorderThickness="0"
                                   HorizontalAlignment="Stretch" Margin="0,0,0,10" Height="40"/>

						<ui:Button x:Name="BtnSettings" Content="Настройки" Foreground="White" Appearance="Transparent" BorderThickness="0"
                                   HorizontalAlignment="Stretch" Margin="0,0,0,10" Height="40" Click="BtnSettings_Click"/>
					</StackPanel>
                </Border>

                <Border Grid.Column="0" HorizontalAlignment="Right" Width="1" Background="#2A2A2A"/>
                <ContentControl Grid.Column="1" x:Name="MainContentContainer" Background="#121212"/>
            </Grid>
        </Grid>
    </Border>
</Window>