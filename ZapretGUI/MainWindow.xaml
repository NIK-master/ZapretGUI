<Window x:Class="ZapretGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Запрет для СДВГ" Height="550" Width="400"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}" WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок -->
            <RowDefinition Height="Auto"/>
            <!-- Статус -->
            <RowDefinition Height="Auto"/>
            <!-- Комбобокс -->
            <RowDefinition Height="Auto"/>
            <!-- Переключатель -->
            <RowDefinition Height="*"/>
            <!-- Окно логов -->
            <RowDefinition Height="Auto"/>
            <!-- Подвал с кнопками -->
        </Grid.RowDefinitions>

        <!-- 1. Зона статуса -->
        <TextBlock Grid.Row="0" Text="Запрет для СДВГ" Foreground="White" FontSize="32"
                   FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,10,0,5"/>

        <TextBlock Grid.Row="1" x:Name="StatusText" Text="Остановлен" Foreground="#D13438" 
                   FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- 2. Зона управления (Явно указываем выравнивание по центру) -->
        <ComboBox Grid.Row="2" x:Name="ProfileComboBox" Width="280" Height="35" 
                  Margin="0,0,0,15" FontSize="14" HorizontalAlignment="Center"/>

        <!-- Используем красивый ползунок из библиотеки WPF-UI -->
        <ui:ToggleSwitch Grid.Row="3" x:Name="MainToggle" Content="Off" 
                         HorizontalAlignment="Center" Margin="0,0,0,20" FontSize="16" 
                         Click="MainToggle_Click"/>

        <!-- 3. Черный квадрат (Логи) -->
        <TextBox Grid.Row="4" x:Name="LogTextBox" Background="#1E1E1E" Foreground="LightGray" 
                 IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,20" FontFamily="Consolas" Text="Ожидание запуска..."/>

        <!-- 4. Зона утилит (Футер) -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <!-- Отступ -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ui:Button Grid.Column="0" x:Name="BtnOpenFolder" Content="Папка запрета" 
                       HorizontalAlignment="Stretch" Height="35" FontSize="14" Click="BtnOpenFolder_Click"/>

            <ui:Button Grid.Column="2" x:Name="BtnService" Content="Сервис" 
                       HorizontalAlignment="Stretch" Height="35" FontSize="14" Click="BtnService_Click"/>
        </Grid>
    </Grid>
</Window>