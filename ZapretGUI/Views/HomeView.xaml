<UserControl x:Class="ZapretGUI.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Foreground="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,30">
            <TextBlock Text="⚡ Починить Telegram и Discord" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="Одна кнопка — запустит всё необходимое." Foreground="#888888" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                <ToggleButton x:Name="MainToggle" Width="200" Height="200" Click="MainToggle_Click" Cursor="Hand" Background="Transparent" BorderThickness="0">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="BtnBorder" Background="#121212" BorderBrush="#2A2A2A" BorderThickness="3" CornerRadius="100">
                                <Border.Effect>
                                    <DropShadowEffect x:Name="ButtonGlow" Color="#107C10" BlurRadius="20" ShadowDepth="0" Opacity="0"/>
                                </Border.Effect>

                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="50" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="BtnText" Text="Починить интернет" FontSize="14" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#107C10"/>
                                    <Setter TargetName="BtnText" Property="Text" Value="Остановить"/>
                                </Trigger>

                                <EventTrigger RoutedEvent="ToggleButton.Checked">
                                    <BeginStoryboard Name="PulseStoryboard">
                                        <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="ButtonGlow" Storyboard.TargetProperty="Opacity" 
                                                             From="0.3" To="0.9" Duration="0:0:1.5" />
                                            <DoubleAnimation Storyboard.TargetName="ButtonGlow" Storyboard.TargetProperty="BlurRadius" 
                                                             From="30" To="70" Duration="0:0:1.5" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>

                                <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                                    <StopStoryboard BeginStoryboardName="PulseStoryboard" />
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonGlow" Storyboard.TargetProperty="Opacity" 
                                                             To="0" Duration="0:0:0.3" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>

                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
            </Grid>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <Border Background="#181818" CornerRadius="12" BorderBrush="#2A2A2A" BorderThickness="1" Margin="0,0,0,15">
                    <Border.Effect>
                        <DropShadowEffect Color="#107C10" BlurRadius="30" ShadowDepth="0" Opacity="0.15"/>
                    </Border.Effect>

                    <StackPanel Margin="20">
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="Настройки Zapret" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <ui:ToggleSwitch x:Name="ZapretToggle" IsChecked="True" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock x:Name="StatusText" Text="Остановлен" Foreground="#D13438" Margin="0,0,0,15"/>

                        <TextBlock Text="Конфигурация:" Foreground="#888888" FontSize="12" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ProfileComboBox" Height="35"/>
                    </StackPanel>
                </Border>

                <Border Background="#181818" CornerRadius="12" BorderBrush="#2A2A2A" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#0088CC" BlurRadius="30" ShadowDepth="0" Opacity="0.15"/>
                    </Border.Effect>

                    <StackPanel Margin="20">
                        <Grid Margin="0,0,0,5">
                            <TextBlock Text="TgWsProxy" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <ui:ToggleSwitch x:Name="TgProxyToggle" IsChecked="True" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Прокси для Telegram" Foreground="#888888" FontSize="12" Margin="0,0,0,15"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Background="#0A0A0A" CornerRadius="8" BorderBrush="#2A2A2A" BorderThickness="1" Margin="0,20,0,0">
            <Grid>
                <TextBlock Text="Лог событий" Foreground="#555555" Margin="15,10,0,0" FontSize="12" FontWeight="SemiBold"/>
                <ScrollViewer Margin="15,30,15,10">
                    <TextBlock x:Name="LogTextBox" Text="[Система] Интерфейс загружен. Ожидание команд..." 
                               Foreground="#888888" FontFamily="Consolas" FontSize="13" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>