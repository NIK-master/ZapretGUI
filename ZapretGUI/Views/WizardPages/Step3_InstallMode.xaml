<UserControl x:Class="ZapretGUI.Views.WizardPages.Step3_InstallMode"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="White">

    <UserControl.Resources>
        <Style TargetType="RadioButton">
            <Setter Property="Background" Value="#181818"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#555555"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="BorderBrush" Value="#107C10"/>
                                <Setter Property="Background" Value="#122415"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="500">
        <TextBlock Text="Выбор режима настройки" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,25"/>

        <RadioButton x:Name="RadioAuto" IsChecked="True" GroupName="InstallMode">
            <StackPanel>
                <TextBlock Text="Автоматическая настройка (Рекомендуется)" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Text="Программа сама выберет оптимальный general.bat профиль и включит нужные службы. Подходит для большинства провайдеров." Foreground="#888888" FontSize="13" TextWrapping="Wrap" Margin="0,5,0,0"/>
            </StackPanel>
        </RadioButton>

        <RadioButton x:Name="RadioManual" GroupName="InstallMode">
            <StackPanel>
                <TextBlock Text="Ручной выбор (Для продвинутых)" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Text="Вы самостоятельно выберете конфигурационные .bat файлы и укажете, какие службы требуют запуска." Foreground="#888888" FontSize="13" TextWrapping="Wrap" Margin="0,5,0,0"/>
            </StackPanel>
        </RadioButton>
    </StackPanel>
</UserControl>