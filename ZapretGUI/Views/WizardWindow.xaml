<Window x:Class="ZapretGUI.Views.WizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Мастер настройки" Height="540" Width="650"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Border Background="#0A0A0A" CornerRadius="12" BorderBrush="#2A2A2A" BorderThickness="1">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="Первоначальная настройка" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Zapret for ADHD v2.0" Foreground="#555555" FontSize="12" Margin="0,2,0,0"/>
            </StackPanel>

            <ContentControl x:Name="WizardContent" Grid.Row="1" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" RenderTransformOrigin="0.5,0.5">
                <ContentControl.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="ContentScale" ScaleX="1" ScaleY="1"/>
                        <TranslateTransform x:Name="ContentTranslate" X="0" Y="0"/>
                    </TransformGroup>
                </ContentControl.RenderTransform>
            </ContentControl>

            <Grid Grid.Row="2" Margin="0,15,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>

                    <ColumnDefinition Width="*"/>

                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="BtnCloseWizard" Content="Пропустить" Background="#1A1A1A" Foreground="White" BorderBrush="#333333" BorderThickness="1" Padding="15,8" HorizontalAlignment="Left" Cursor="Hand" Click="BtnCloseWizard_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
                
                <StackPanel Grid.Column="1" x:Name="ProgressDots" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnBack" Content="Назад" Background="#1A1A1A" Foreground="White" BorderBrush="#333333" BorderThickness="1" Padding="15,8" Margin="0,0,10,0" Cursor="Hand" Click="BtnBack_Click" Visibility="Collapsed">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button x:Name="BtnNextStep" Content="Начать настройку" Background="#107C10" Foreground="White" BorderThickness="0" Padding="15,8" Cursor="Hand" Click="BtnNextStep_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>